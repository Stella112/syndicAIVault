{
  "version": 2,
  "rewrites": [
    {
      "source": "/ledger/(.*)",
      "destination": "https://ledger-api-json.participant.hackcanton-01.devnet.naas.noders.services/$1"
    },
    {
      "source": "/keycloak/(.*)",
      "destination": "https://keycloak.naas.noders.services/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
